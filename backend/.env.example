# ============================================================
# MediChain Backend — Environment Variables Template
# ============================================================
# SAO CHÉP file này thành .env rồi điền giá trị THẬT vào.
# TUYỆT ĐỐI KHÔNG commit file .env (đã có trong .gitignore).
# ============================================================

# ─── Database ───────────────────────────────────────────────
# Local dev (Docker): dùng host 127.0.0.1 hoặc tên service Docker
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public"

# ─── JWT Authentication ──────────────────────────────────────
# BẮT BUỘC. Tạo secret ngẫu nhiên 64 bytes bằng lệnh:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_RANDOM_128_CHAR_HEX_STRING"
JWT_EXPIRES_IN="7d"

# ─── NextAuth (nếu dùng) ────────────────────────────────────
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI Services ─────────────────────────────────────────────
# Gemini API — dùng cho Vector Embedding (Semantic Search)
# Lấy tại: https://ai.google.dev/
GEMINI_API_KEY="REPLACE_WITH_YOUR_GEMINI_API_KEY"

# Groq API — dùng cho AI Chat (nếu cấu hình)
# Lấy tại: https://console.groq.com/
GROQ_API_KEY="REPLACE_WITH_YOUR_GROQ_API_KEY"

# ─── Server Config ───────────────────────────────────────────
PORT=5000

# ─── Email Service (Password Reset) ─────────────────────────
# Dùng Gmail App Password:
#   myaccount.google.com → Security → 2-Step Verification → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=noreply@medichain.app

# ─── Frontend URL ────────────────────────────────────────────
# Dùng trong link reset password email và CORS whitelist
# Nhiều URL: phân cách bằng dấu phẩy (vd: http://localhost:3000,https://app.medichain.vn)
FRONTEND_URL=http://localhost:3000
