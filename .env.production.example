# ============================================================
# MediChain — Production Environment Variables Template
# ============================================================
# Hướng dẫn:
#   1. Copy file này: cp .env.production.example .env.production
#   2. Điền TẤT CẢ các giá trị THẬT vào .env.production
#   3. KHÔNG BAO GIỜ commit .env.production lên Git
#   4. Deploy: docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# ============================================================

# ─── Database ───────────────────────────────────────────────
POSTGRES_USER=medichain_user
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD_32CHARS+
POSTGRES_DB=medichain_db

# ─── JWT Authentication ──────────────────────────────────────
# Tạo secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_WITH_THE_COMMAND_ABOVE_128_CHARS
JWT_EXPIRES_IN=7d

# ─── AI Services ─────────────────────────────────────────────
# Gemini API: https://ai.google.dev/ → Get API key
GEMINI_API_KEY=your_real_gemini_api_key_here

# Groq API: https://console.groq.com/ → API Keys
GROQ_API_KEY=your_real_groq_api_key_here

# ─── Email Service ────────────────────────────────────────────
# Gmail App Password:
#   Google Account → Security → 2-Step Verification → App Passwords
#   Chọn app: "Mail", device: "Other" → Copy 16-char password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail_account@gmail.com
EMAIL_PASS=your_16_char_app_password_no_spaces
EMAIL_FROM=noreply@medichain.app

# ─── URLs ─────────────────────────────────────────────────────
# Thay bằng domain/IP thật của server bạn
# Ví dụ: https://medichain.yourdomain.com hoặc http://123.456.789.0
FRONTEND_URL=http://your-server-ip-or-domain
